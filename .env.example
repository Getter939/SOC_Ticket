# Copy this file to .env and fill in your values
# cp .env.example .env   (Linux/macOS)
# copy .env.example .env (Windows)

SECRET_KEY=your-django-secret-key-here

# Set DEBUG=False in any non-local deployment. DEBUG=True leaks stack traces,
# settings, and SQL to anyone who triggers an error. Default is False so an
# accidental copy-to-prod stays safe; flip to True only for local development.
DEBUG=False

# Comma-separated list of hostnames/IPs this server will respond to (no
# spaces). Must include the LAN IP/hostname other users browse to, plus
# "web" for the Docker service-to-service requests behind nginx.
ALLOWED_HOSTS=192.168.x.x,localhost,127.0.0.1,web

# ── HTTPS security (production behind TLS) ──────────────────────────────────
# Leave these unset/False for a local or internal-HTTP deployment. When the
# app is served over HTTPS, set them to True to stop cookies and traffic from
# being sent in clear text:
#   SESSION_COOKIE_SECURE=True
#   CSRF_COOKIE_SECURE=True
#   SECURE_SSL_REDIRECT=True
#   SECURE_HSTS_SECONDS=31536000   # 1 year; start small (e.g. 3600) to test
#   PASSWORD_RESET_USE_HTTPS=True  # send password-reset links only over HTTPS
#
# Behind a TLS-terminating reverse proxy (the bundled nginx forwards
# X-Forwarded-Proto), also set this so Django detects HTTPS correctly —
# REQUIRED for SECURE_SSL_REDIRECT/HSTS to work behind the proxy without loops.
# Only enable when the proxy strips client-supplied X-Forwarded-Proto.
#   USE_PROXY_SSL_HEADER=True

DB_NAME=ticketdata
DB_USER=ticket
DB_PASSWORD=your-db-password-here
DB_HOST=localhost
DB_PORT=5432

CSV_DIR=

# ── Email / SMTP ──────────────────────────────────────────────────────────
# EMAIL_BACKEND: leave unset for real SMTP. On a UAT/demo box, set it to the
# console backend so notifications print to the container log instead of
# emailing real recipients:
#   EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
#
# EMAIL_PORT: use 587 (STARTTLS) with EMAIL_USE_TLS=True  ← recommended
#             use 465 (SMTPS)   with EMAIL_USE_SSL=True, EMAIL_USE_TLS=False
#             do NOT combine port 25 with EMAIL_USE_TLS=True
EMAIL_HOST=smtp.your-provider.com
EMAIL_HOST_USER=your-smtp-username@example.com
EMAIL_HOST_PASSWORD=your-smtp-password-here
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
# DEFAULT_FROM_EMAIL: the "From:" address on outgoing emails.
# Defaults to EMAIL_HOST_USER when not set.
DEFAULT_FROM_EMAIL=SOC Notifications <noreply@example.com>

# ── Site URL ──────────────────────────────────────────────────────────────
# Used to build absolute links in email notifications.
# No trailing slash. Set to your public hostname in production.
SITE_URL=http://localhost:8088

# ── Wazuh / OpenSearch alert ingestion ─────────────────────────────────────
# OpenSearch REST API — alerts live at https://<HOST>:<PORT>/wazuh-alerts-*/_search
# Auth is HTTP Basic. The cluster uses a self-signed TLS cert by default,
# so OPENSEARCH_VERIFY_SSL=False unless you've installed a trusted CA cert.
# RECOMMENDED: export the cluster's CA cert to a PEM file and point
# OPENSEARCH_CA_BUNDLE at it — this enables TLS verification (preventing MITM
# on the alert feed) without needing the cert in the system trust store.
# If OPENSEARCH_CA_BUNDLE is set, it takes precedence over OPENSEARCH_VERIFY_SSL.
OPENSEARCH_HOST=10.x.x.x
OPENSEARCH_PORT=9200
OPENSEARCH_USER=your_opensearch_user
OPENSEARCH_PASSWORD=your_opensearch_password
OPENSEARCH_VERIFY_SSL=False
# OPENSEARCH_CA_BUNDLE=/etc/ssl/certs/opensearch-ca.pem

# Backup / restore verification
# On the VM, prefer a path outside the repo, e.g. /srv/soc-ticket/backups or a
# mounted backup disk. The default is convenient for local testing and is
# ignored by git.
BACKUP_HOST_PATH=./backups
BACKUP_PREFIX=soc_ticket

# The backup job uses BACKUP_TIER in the filename and retention cleanup. Use
# manual for ad-hoc runs, then set hourly/daily/weekly/monthly from cron or a
# systemd timer.
BACKUP_TIER=manual
BACKUP_RETENTION_ENABLED=true
BACKUP_RETENTION_HOURLY_DAYS=2
BACKUP_RETENTION_DAILY_DAYS=30
BACKUP_RETENTION_WEEKLY_DAYS=84
BACKUP_RETENTION_MONTHLY_DAYS=365

# Encryption is disabled by default so first restore testing is simple. For
# production, choose openssl or gpg. Prefer a password file or GPG recipient
# instead of placing a long-lived password directly in .env.
BACKUP_ENCRYPTION=none
# BACKUP_ENCRYPTION_PASSWORD_FILE=/run/secrets/soc_ticket_backup_password
# BACKUP_ENCRYPTION_PASSWORD=change-me-only-if-you-accept-env-secret-risk
# BACKUP_GPG_RECIPIENT=security-backups@example.com

# Restore verification recreates this database and compares row/media counts.
RESTORE_DB=ticketdata_restoretest
RESTORE_DROP_AFTER_TEST=false

DB_CONN_MAX_AGE=0
DB_SSLMODE=prefer