# Git
.git
.gitignore

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environments
venv/
env/
.venv/

# Environment / secrets
.env
# Local-dev settings override (DEBUG=True, console email). Gitignored, but
# docker builds copy the working tree — keep it out of the image so a local
# build can never ship DEBUG=True.
config/settings_local.py

# Database files
*.sqlite3
db.sqlite3

# Django collected static (rebuild inside container)
staticfiles/
media/

# Logs
*.log
logs/
backups/

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
